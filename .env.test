# The ID of your GitHub App
# APP_ID=123456
# WEBHOOK_SECRET=testsecret

# Use `trace` to get verbose logging or `info` to show less
LOG_LEVEL=debug

# Go to https://smee.io/new set this to the URL that you are redirected to.
WEBHOOK_PROXY_URL=

DITTOBOT_STORE__ENROLLED_REPOS=octocat/hello-world,octocat/another-repo
DITTOBOT_STORE__MERGE_STRATEGY=squash
DITTOBOT_STORE__ORG=octocat
DITTOBOT_STORE__REQUIRE_CI=true
DITTOBOT_STORE__TYPE=memory
DITTOBOT_STRICT_VERSIONS=true
