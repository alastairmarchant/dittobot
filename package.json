{
    "name": "dittobot",
    "version": "1.0.0",
    "private": true,
    "description": "Automatically approves and merges Dependabot PRs across multiple repos once a dependency version has been manually reviewed in any single repo.",
    "author": "Alastair Marchant",
    "license": "ISC",
    "homepage": "https://github.com/alastairmarchant/dittobot",
    "keywords": [
        "probot",
        "github",
        "probot-app"
    ],
    "type": "module",
    "scripts": {
        "build": "tsc && chmod +x dist/cli.js",
        "start": "probot run ./dist/index.js",
        "cli": "node ./dist/cli.js",
        "test": "vitest",
        "lint": "npx --node-options='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config .",
        "lint:fix": "npm run lint -- --fix",
        "lint:report": "npm run lint -- --format html --output-file lint-report.html",
        "typecheck": "tsc --noEmit",
        "format:write": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "validate": "npm run typecheck && npm run lint && npm run format:check",
        "prepublishOnly": "npm run build",
        "prepare": "husky || true"
    },
    "bin": {
        "dittobot": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@commander-js/extra-typings": "^14.0.0",
        "commander": "^14.0.3",
        "compare-versions": "^6.1.1",
        "probot": "^14.3.2",
        "yaml": "^2.8.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.0.0",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "ioredis": "^5.10.1",
        "json-schema-faker": "^0.6.1",
        "lint-staged": "^17.0.4",
        "nock": "^14.0.5",
        "prettier": "^3.8.3",
        "smee-client": "^5.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3",
        "vitest": "^3.2.4"
    },
    "overrides": {
        "@types/pg": "8.15.1"
    },
    "engines": {
        "node": "^20.18.1 || >= 22"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "npm run lint:fix",
            "npm run format:write"
        ]
    }
}
