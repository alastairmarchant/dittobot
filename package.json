{
  "name": "dittobot",
  "version": "1.0.0",
  "private": true,
  "description": "Automatically approves and merges Dependabot PRs across multiple repos once a dependency version has been manually reviewed in any single repo.",
  "author": "Alastair Marchant",
  "license": "ISC",
  "homepage": "https://github.com/alastairmarchant/dittobot",
  "keywords": [
    "probot",
    "github",
    "probot-app"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "start": "probot run ./dist/index.js",
    "test": "vitest",
    "cli": "node ./dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "dittobot": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.3",
    "compare-versions": "^6.1.1",
    "probot": "^14.3.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ioredis": "^5.10.1",
    "json-schema-faker": "^0.6.1",
    "nock": "^14.0.5",
    "smee-client": "^5.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@types/pg": "8.15.1"
  },
  "engines": {
    "node": "^20.18.1 || >= 22"
  },
  "type": "module"
}
